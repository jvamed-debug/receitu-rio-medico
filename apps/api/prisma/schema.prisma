generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PROFESSIONAL
  ASSISTANT
  ADMIN
  COMPLIANCE
}

enum ProfessionalStatus {
  PENDING_VALIDATION
  ACTIVE
  SUSPENDED
}

enum DocumentType {
  PRESCRIPTION
  EXAM_REQUEST
  MEDICAL_CERTIFICATE
  FREE_DOCUMENT
}

enum DocumentStatus {
  DRAFT
  READY_FOR_REVIEW
  PENDING_SIGNATURE
  SIGNED
  ISSUED
  DELIVERED
  ARCHIVED
}

enum SignatureProvider {
  ICP_BRASIL_VENDOR
  GOVBR_VENDOR
}

enum SignatureSessionStatus {
  PENDING
  AUTHORIZED
  SIGNED
  EXPIRED
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum BillingStatus {
  PENDING
  AUTHORIZED
  PAID
  CANCELLED
  REFUNDED
}

enum CdsOverrideReviewStatus {
  PENDING
  ACKNOWLEDGED
  APPROVED
  REJECTED
}

enum PharmacyOrderStatus {
  PENDING
  CHECKOUT_READY
  ORDER_PLACED
  CONFIRMED
  FULFILLED
  CANCELLED
  FAILED
}

enum EncounterType {
  CONSULTATION
  FOLLOW_UP
  TELEHEALTH
  TRIAGE
  PROCEDURE
  CLINICAL_NOTE
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  passwordHash       String
  fullName           String
  role               UserRole             @default(PROFESSIONAL)
  professionalProfile ProfessionalProfile?
  templateFavorites  UserTemplateFavorite[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model ProfessionalProfile {
  id                   String             @id @default(cuid())
  userId               String             @unique
  primaryOrganizationId String?
  documentNumber       String
  councilType          String
  councilState         String
  rqe                  String?
  cbo                  String?
  specialty            String?
  cnes                 String?
  signatureProvider    SignatureProvider?
  signatureValidatedAt DateTime?
  status               ProfessionalStatus @default(PENDING_VALIDATION)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryOrganization  Organization?      @relation("PrimaryOrganizationProfiles", fields: [primaryOrganizationId], references: [id], onDelete: SetNull)
  memberships          OrganizationMembership[]
  documents            ClinicalDocument[]
  appointments         Appointment[]
  primaryPatients      Patient[]          @relation("PrimaryProfessionalPatients")
  reviewedClinicalProfiles PatientClinicalProfile[]
  encounters           PatientEncounter[]
  evolutions           PatientEvolution[]
  signatureSessions    SignatureSession[]
  requestedCdsOverrideReviews CdsOverrideReview[] @relation("RequestedCdsOverrideReviews")
  reviewedCdsOverrideReviews CdsOverrideReview[]  @relation("ReviewedCdsOverrideReviews")
  auditLogs            AuditLog[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Organization {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  settings           Json?
  memberships        OrganizationMembership[]
  invitations        OrganizationInvitation[]
  primaryProfiles    ProfessionalProfile[]    @relation("PrimaryOrganizationProfiles")
  patients           Patient[]
  documents          ClinicalDocument[]
  appointments       Appointment[]
  encounters         PatientEncounter[]
  evolutions         PatientEvolution[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}

model OrganizationMembership {
  id               String               @id @default(cuid())
  organizationId   String
  professionalId   String
  membershipRole   String               @default("owner")
  status           MembershipStatus     @default(ACTIVE)
  isDefault        Boolean              @default(false)
  invitedByUserId  String?
  deactivatedAt    DateTime?
  createdAt        DateTime             @default(now())
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professional     ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([organizationId, professionalId])
  @@index([professionalId, isDefault])
}

model OrganizationInvitation {
  id                String            @id @default(cuid())
  organizationId    String
  email             String
  membershipRole    String            @default("member")
  status            InvitationStatus  @default(PENDING)
  invitedByUserId   String?
  expiresAt         DateTime?
  acceptedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([email, status])
}

model Patient {
  id         String             @id @default(cuid())
  organizationId String?
  fullName   String
  cpf        String?            @unique
  cns        String?            @unique
  birthDate  DateTime?
  phone      String?
  email      String?
  notes      String?
  primaryProfessionalId String?
  clinicalProfile PatientClinicalProfile?
  documents  ClinicalDocument[]
  appointments Appointment[]
  encounters   PatientEncounter[]
  evolutions   PatientEvolution[]
  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  primaryProfessional ProfessionalProfile? @relation("PrimaryProfessionalPatients", fields: [primaryProfessionalId], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([primaryProfessionalId])
  @@index([organizationId])
}

model Appointment {
  id                    String               @id @default(cuid())
  organizationId        String?
  patientId             String
  professionalId        String
  title                 String
  status                AppointmentStatus    @default(SCHEDULED)
  appointmentAt         DateTime
  durationMinutes       Int                  @default(30)
  notes                 String?
  telehealth            Boolean              @default(false)
  telehealthUrl         String?
  telehealthProvider    String?
  telehealthRoomId      String?
  billingEntries        AppointmentBilling[]
  reminders             AppointmentReminder[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  organization          Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  patient               Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional          ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([organizationId, appointmentAt])
  @@index([professionalId, appointmentAt])
  @@index([patientId, appointmentAt])
}

model AppointmentBilling {
  id                String         @id @default(cuid())
  appointmentId     String
  status            BillingStatus  @default(PENDING)
  amountCents       Int
  currency          String         @default("BRL")
  description       String
  paymentProvider   String?
  externalReference String?
  authorizedAt      DateTime?
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  appointment       Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  webhookEvents     AppointmentBillingWebhookEvent[]

  @@index([appointmentId, status])
  @@index([status, createdAt])
}

model AppointmentReminder {
  id              String          @id @default(cuid())
  appointmentId   String
  channel         String
  status          ReminderStatus  @default(PENDING)
  target          String?
  scheduledFor    DateTime
  sentAt          DateTime?
  nextAttemptAt   DateTime?
  attemptCount    Int             @default(0)
  lastError       String?
  message         String
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, scheduledFor])
  @@index([status, scheduledFor])
}

model AppointmentBillingWebhookEvent {
  id                String             @id @default(cuid())
  appointmentId     String
  billingId         String
  eventKey          String             @unique
  eventId           String?
  providerReference String?
  status            BillingStatus
  payload           Json?
  resultStatus      String?
  processedAt       DateTime?
  createdAt         DateTime           @default(now())
  billing           AppointmentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
  @@index([billingId, createdAt])
}

model PatientClinicalProfile {
  id                     String               @id @default(cuid())
  patientId              String               @unique
  allergies              Json?
  conditions             Json?
  chronicMedications     Json?
  carePlan               Json?
  summary                String?
  reviewedByProfessionalId String?
  reviewedAt             DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  patient                Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviewedByProfessional ProfessionalProfile? @relation(fields: [reviewedByProfessionalId], references: [id], onDelete: SetNull)

  @@index([reviewedByProfessionalId, reviewedAt])
}

model PatientEncounter {
  id               String              @id @default(cuid())
  patientId        String
  organizationId   String?
  professionalId   String
  type             EncounterType       @default(CLINICAL_NOTE)
  title            String
  summary          String?
  notes            String?
  occurredAt       DateTime
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  patient          Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([patientId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([professionalId, occurredAt])
}

model PatientEvolution {
  id               String              @id @default(cuid())
  patientId        String
  organizationId   String?
  professionalId   String
  encounterId      String?
  title            String
  subjective       String?
  objective        String?
  assessment       String?
  plan             String?
  tags             Json?
  occurredAt       DateTime
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  patient          Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([patientId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([professionalId, occurredAt])
}

model ClinicalDocument {
  id                    String               @id @default(cuid())
  type                  DocumentType
  status                DocumentStatus       @default(DRAFT)
  organizationId        String?
  patientId             String
  authorProfessionalId  String
  title                 String
  payload               Json
  layoutVersion         String
  payloadHash           String?
  issuedAt              DateTime?
  derivedFromDocumentId String?
  organization          Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  patient               Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  authorProfessional    ProfessionalProfile  @relation(fields: [authorProfessionalId], references: [id], onDelete: Restrict)
  signatures            SignatureSession[]
  deliveries            DeliveryEvent[]
  shareTokens           DocumentShareToken[]
  cdsOverrideReviews    CdsOverrideReview[]
  pharmacyOrders        PharmacyOrder[]
  pdfArtifact           PdfArtifact?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([organizationId, authorProfessionalId])
}

model CdsOverrideReview {
  id                     String                  @id @default(cuid())
  documentId             String
  organizationId         String?
  requestedByProfessionalId String
  reviewedByProfessionalId  String?
  status                 CdsOverrideReviewStatus @default(PENDING)
  alertCodes             Json?
  justification          String
  resolutionNotes        String?
  reviewedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  document               ClinicalDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  requestedByProfessional ProfessionalProfile    @relation("RequestedCdsOverrideReviews", fields: [requestedByProfessionalId], references: [id], onDelete: Cascade)
  reviewedByProfessional ProfessionalProfile?    @relation("ReviewedCdsOverrideReviews", fields: [reviewedByProfessionalId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([requestedByProfessionalId, status])
  @@index([documentId, status])
}

model PharmacyOrder {
  id                String              @id @default(cuid())
  documentId        String
  provider          String
  providerMode      String?
  quoteId           String
  status            PharmacyOrderStatus @default(PENDING)
  externalReference String?
  checkoutUrl       String?
  partnerOrderUrl   String?
  totalPriceCents   Int
  currency          String              @default("BRL")
  items             Json?
  warnings          Json?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  document          ClinicalDocument    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([status, createdAt])
  @@index([externalReference])
}

model Template {
  id          String       @id @default(cuid())
  name        String
  type        DocumentType
  version     Int          @default(1)
  structure   Json
  favoritedBy UserTemplateFavorite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model UserTemplateFavorite {
  id         String    @id @default(cuid())
  userId     String
  presetKey  String
  label      String?
  category   String?
  templateId String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([userId, presetKey])
  @@index([userId, createdAt])
}

model SignatureSession {
  id              String                 @id @default(cuid())
  professionalId  String
  documentId      String
  provider        SignatureProvider
  status          SignatureSessionStatus @default(PENDING)
  signatureLevel  String?
  policyVersion   String?
  providerReference String?
  evidence        Json?
  expiresAt       DateTime?
  signedAt        DateTime?
  createdAt       DateTime               @default(now())
  professional    ProfessionalProfile    @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  document        ClinicalDocument       @relation(fields: [documentId], references: [id], onDelete: Restrict)
}

model PdfArtifact {
  id          String            @id @default(cuid())
  documentId  String            @unique
  storageKey  String
  sha256      String
  metadata    Json?
  createdAt   DateTime          @default(now())
  document    ClinicalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DeliveryEvent {
  id          String            @id @default(cuid())
  documentId  String
  channel     String
  target      String?
  status      String
  metadata    Json?
  createdAt   DateTime          @default(now())
  document    ClinicalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentShareToken {
  id              String            @id @default(cuid())
  documentId      String
  tokenHash       String            @unique
  purpose         String
  expiresAt       DateTime
  revokedAt       DateTime?
  maxUses         Int               @default(1)
  usedCount       Int               @default(0)
  createdByUserId String?
  lastUsedAt      DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  document        ClinicalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, expiresAt])
}

model AuditLog {
  id                   String               @id @default(cuid())
  actorUserId          String?
  actorProfessionalId  String?
  entityType           String
  entityId             String
  action               String
  correlationId        String
  origin               String
  metadata             Json
  occurredAt           DateTime             @default(now())
  actorProfessional    ProfessionalProfile? @relation(fields: [actorProfessionalId], references: [id], onDelete: SetNull)
}
